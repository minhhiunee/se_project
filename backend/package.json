{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Basic ecommerce backend skeleton using Node.js and Express",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prisma:generate": "node scripts/with-env.js npx prisma generate",
    "prisma:migrate": "node scripts/with-env.js npx prisma migrate dev",
    "prisma:studio": "node scripts/with-env.js npx prisma studio",
    "db:seed": "node scripts/with-env.js node prisma/seed.js",
    "db:list-users": "node scripts/listUsers.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "prisma": "6.19.0"
  }
}
